FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /tuckcsi ./cmd/tuckcsi

# distroless/static without nonroot — the DaemonSet runs privileged for mount syscalls
FROM gcr.io/distroless/static:latest
COPY --from=builder /tuckcsi /tuckcsi
ENTRYPOINT ["/tuckcsi"]
