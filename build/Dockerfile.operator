FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /tuck-operator ./cmd/tuck-operator

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /tuck-operator /tuck-operator
USER 65532:65532
ENTRYPOINT ["/tuck-operator"]
